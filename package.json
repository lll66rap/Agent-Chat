    "@epicgames-ps/lib-pixelstreamingfrontend-ue5.7": "^0.2.2",
    "@traptitech/markdown-it-katex": "^3.6.0",
    "katex": "^0.16.45",
    "markdown-it": "^14.1.0",
    "vue": "^3.4.21"
  },
  "devDependencies": {
    "@types/markdown-it": "^14.1.2",
